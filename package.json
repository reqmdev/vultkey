{
  "name": "vultkey",
  "version": "0.1.0",
  "description": "Secure self-hostable dashboard for organizing digital keys, licenses, coupons, and credentials.",
  "private": true,
  "license": "MIT",
  "keywords": [
    "nextjs",
    "supabase",
    "vault",
    "keys",
    "license-management"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "security:check": "node scripts/security-check.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preflight:prod": "node scripts/preflight.mjs --production",
    "publish:check": "node scripts/publish-check.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "clean:artifacts": "powershell -ExecutionPolicy Bypass -File scripts/clean-artifacts.ps1",
    "backup:db": "powershell -ExecutionPolicy Bypass -File scripts/backup-supabase.ps1",
    "db:push": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-migration.ps1"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.106.1",
    "@tanstack/react-table": "8.21.3",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-icons": "^5.6.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5.11",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2"
}
