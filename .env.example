NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"

# Use either SUPABASE_DB_URL for migration push, or Supabase CLI linking credentials.
SUPABASE_DB_URL="postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres"
# SUPABASE_ACCESS_TOKEN="sbp_your_access_token"
# SUPABASE_DB_PASSWORD="your-db-password"

# 32 random bytes, base64 encoded. Example: openssl rand -base64 32
VULTKEY_ENCRYPTION_KEY="base64_32_byte_key"

# 32+ random bytes, base64 encoded. Example: openssl rand -base64 32
VULTKEY_HMAC_KEY="base64_32_plus_byte_key"

UPSTASH_REDIS_REST_URL="https://your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Login/signup/password-reset bot protection. Required in production.
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY="your_turnstile_site_key"
CLOUDFLARE_TURNSTILE_SECRET_KEY="your_turnstile_secret_key"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_recaptcha_v3_site_key"
RECAPTCHA_SECRET_KEY="your_recaptcha_v3_secret_key"
RECAPTCHA_MIN_SCORE="0.5"
# Optional. Defaults to NEXT_PUBLIC_APP_URL hostname when it is not localhost.
# BOT_PROTECTION_EXPECTED_HOSTNAME="your-domain.com"

# Optional. Prefer a platform-controlled header such as cf-connecting-ip.
# Set TRUST_X_FORWARDED_FOR=true only when your edge/proxy strips client-supplied X-Forwarded-For.
# TRUSTED_CLIENT_IP_HEADER="cf-connecting-ip"
# TRUST_X_FORWARDED_FOR="false"

# Required in production for account deletion and trusted audit writes.
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
